# ─── LLM Providers ───────────────────────────────────────────────
# Nebius AI Studio — powers all notebooks (get yours at https://studio.nebius.ai)
NEBIUS_API_KEY="your_nebius_api_key_here"

# ─── Search Tool ─────────────────────────────────────────────────
# Tavily — used in tool-use and ReAct notebooks (free tier at https://tavily.com)
TAVILY_API_KEY="your_tavily_api_key_here"

# ─── Observability (optional but recommended) ─────────────────────
# LangSmith — traces agent execution graphs (https://smith.langchain.com)
LANGCHAIN_API_KEY="your_langsmith_api_key_here"
LANGCHAIN_TRACING_V2="true"
LANGCHAIN_PROJECT="agentic-architectures"
